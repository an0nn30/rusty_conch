<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs" xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
   <Package Name="Conch" UpgradeCode="f3a1d8b2-6c4e-4a9f-b7d5-2e8c1f0a3b6d" Language="1033" Codepage="1252" Version="2.0.2" Manufacturer="an0nn30" InstallerVersion="200">
      <MajorUpgrade AllowSameVersionUpgrades="yes" DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
      <Icon Id="ConchIco" SourceFile=".\crates\conch_tauri\icons\icon.ico" />
      <WixVariable Id="WixUILicenseRtf" Value=".\packaging\windows\license.rtf" />
      <Property Id="ARPPRODUCTICON" Value="ConchIco" />
      <MediaTemplate EmbedCab="yes" />
      <ui:WixUI Id="WixUI_Minimal" />
      <Feature Id="ProductFeature" Title="ConsoleApp" Level="1">
         <ComponentRef Id="ConchExe" />

         <ComponentRef Id="ConchShortcut" />
         <ComponentRef Id="ModifyPathEnv" />
         <ComponentRef Id="ContextMenu" />
      </Feature>
      <!-- Application binaries -->
      <DirectoryRef Id="ConchProgramFiles">
         <Component Id="ConchExe">
            <File Id="ConchExeFile" Source=".\target\release\conch.exe" Name="conch.exe" KeyPath="yes" />
         </Component>
      </DirectoryRef>
      <DirectoryRef Id="ConchProgramMenu">
         <!-- Application shortcut -->
         <Component Id="ConchShortcut" Guid="b4c2e7a1-5d3f-4e8b-a1c6-9f0d2e7b4a3c">
            <Shortcut Id="ConchShortcutFile" Name="Conch" Description="A cross-platform terminal emulator and SSH client" Target="[ConchProgramFiles]conch.exe" />
            <RemoveFolder Id="ConchProgramMenu" On="uninstall" />
            <RegistryValue Root="HKCU" Key="Software\Microsoft\Conch" Name="installed" Type="integer" Value="1" KeyPath="yes" />
         </Component>
      </DirectoryRef>
      <DirectoryRef Id="ConchProgramFiles">
         <!-- Add to PATH -->
         <Component Id="ModifyPathEnv" Guid="a5d8c3e1-7b2f-4f9a-b6d4-1e0c3a8f5d2b" KeyPath="yes">
            <Environment Id="PathEnv" Value="[ConchProgramFiles]" Name="PATH" Permanent="no" Part="first" Action="set" System="yes" />
         </Component>
      </DirectoryRef>
      <StandardDirectory Id="ProgramFiles64Folder">
         <Directory Id="ConchProgramFiles" Name="Conch" />
      </StandardDirectory>
      <StandardDirectory Id="ProgramMenuFolder">
         <Directory Id="ConchProgramMenu" Name="Conch" />
      </StandardDirectory>
      <!-- Add context menu -->
      <Component Id="ContextMenu" Guid="c6e9f2b3-8a1d-4c7e-b5a3-0d2f1e8c4b7a" Directory="TARGETDIR">
         <RegistryKey Root="HKCU" Key="Software\Classes\Directory\Background\shell\Open Conch here\command">
            <RegistryValue Type="string" Value='[ConchProgramFiles]conch.exe --working-directory "%v"' KeyPath="yes" />
         </RegistryKey>
         <RegistryKey Root="HKCU" Key="Software\Classes\Directory\Background\shell\Open Conch here">
            <RegistryValue Type="string" Name="Icon" Value="[ConchProgramFiles]conch.exe" />
         </RegistryKey>
      </Component>
   </Package>
</Wix>
